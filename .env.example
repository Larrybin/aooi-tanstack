# app
DEPLOY_TARGET = "cloudflare"
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE = "en"
NEXT_PUBLIC_DEBUG = "false"
STORAGE_PUBLIC_BASE_URL = ""

# theme
NEXT_PUBLIC_THEME = "default"

# database
# Required for Node/Vercel runtimes. Cloudflare Workers uses HYPERDRIVE.
DATABASE_URL = ""
DATABASE_PROVIDER = "postgresql"
DB_SINGLETON_ENABLED = "true"

# auth secret
# openssl rand -base64 32
BETTER_AUTH_SECRET = ""
AUTH_SECRET = ""
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""
GITHUB_CLIENT_ID = ""
GITHUB_CLIENT_SECRET = ""
RESEND_API_KEY = ""

# payment runtime bindings only, not settings
STRIPE_PUBLISHABLE_KEY = ""
STRIPE_SECRET_KEY = ""
STRIPE_SIGNING_SECRET = ""
CREEM_API_KEY = ""
CREEM_SIGNING_SECRET = ""
PAYPAL_CLIENT_ID = ""
PAYPAL_CLIENT_SECRET = ""
PAYPAL_WEBHOOK_ID = ""

# ai runtime bindings only, not settings
OPENROUTER_API_KEY = ""
REPLICATE_API_TOKEN = ""
FAL_API_KEY = ""
KIE_API_KEY = ""
AI_NOTIFY_WEBHOOK_SECRET = ""
REMOVER_CLEANUP_SECRET = ""
