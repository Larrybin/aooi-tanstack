{
  "name": "aooi-tanstack",
  "version": "1.2.0",
  "private": true,
  "author": "Larrybin",
  "homepage": "https://github.com/Larrybin/aooi-tanstack",
  "repository": {
    "type": "git",
    "url": "https://github.com/Larrybin/aooi-tanstack.git"
  },
  "keywords": [
    "ai-saas-boilerplate",
    "ai-saas-template",
    "ai-saas-framework",
    "ai-saas-development"
  ],
  "scripts": {
    "dev": "node scripts/run-with-site.mjs pnpm exec vite dev --config vite.config.mts",
    "dev:local": "SITE=dev-local node scripts/run-with-site.mjs pnpm exec vite dev --config vite.config.mts",
    "dev:ai-remover:cloudflare": "SITE=ai-remover pnpm cf:build -- --workers=router,public-web && SITE=ai-remover node scripts/run-with-site.mjs node --import tsx scripts/run-ai-remover-cloudflare-dev.mjs",
    "build": "node scripts/run-with-site.mjs pnpm exec vite build --config vite.config.mts",
    "start": "node scripts/run-with-site.mjs pnpm exec vite preview --config vite.config.mts",
    "typecheck": "node scripts/run-with-site.mjs pnpm exec tsc --noEmit --pretty false --incremental false",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "ci": "pnpm check && SITE=dev-local pnpm build && pnpm client:boundary && pnpm arch:check && pnpm i18n:check --strict",
    "release:check": "pnpm run ci && pnpm cf:check && pnpm cf:build:no-db --site=$SITE && pnpm cf:typegen:check",
    "test": "node scripts/run-with-site.mjs node scripts/run-tests.mjs",
    "test:extended": "pnpm test:auth-spike",
    "test:auth-spike": "node --import tsx scripts/smoke.mjs auth-spike",
    "test:cf-app-smoke": "node scripts/run-with-site.mjs node --import tsx scripts/smoke.mjs cf-app",
    "test:cf-admin-settings-smoke": "pnpm cf:build && node scripts/run-with-site.mjs node --import tsx scripts/smoke.mjs cf-admin-settings",
    "test:cf-local-smoke": "node scripts/run-with-site.mjs node --import tsx scripts/smoke.mjs cf-local",
    "test:admin-settings-module-contract-smoke": "node --import tsx scripts/run-admin-settings-module-contract-smoke.mjs",
    "test:creem-webhook-spike": "node --test --import tsx \"src/infra/adapters/payment/creem.test.ts\" \"tests/contract/payment-notify.test.ts\"",
    "test:remover-guest-limiter-smoke": "SITE=ai-remover pnpm cf:build -- --workers=router,public-web && SITE=ai-remover node scripts/run-with-site.mjs node --import tsx scripts/run-remover-guest-limiter-smoke.mjs",
    "test:remover-workers-ai-spike": "SITE=ai-remover SMOKE_AUTH_REQUIRED=true pnpm cf:build -- --workers=router,public-web && SITE=ai-remover SMOKE_AUTH_REQUIRED=true node scripts/run-with-site.mjs node --import tsx scripts/run-remover-workers-ai-spike.mjs",
    "test:r2-upload-spike": "node --test --import tsx \"src/server/api/storage/upload-image-route.server.test.ts\"",
    "test:coverage": "node scripts/run-with-site.mjs node scripts/run-tests.mjs --coverage",
    "contract:check": "node scripts/check-saas-product-contract.mjs",
    "i18n:check": "node scripts/check-site-i18n.mjs",
    "i18n:glossary:check": "node scripts/check-site-i18n-glossary.mjs",
    "i18n:schema:check": "node scripts/check-site-i18n-schema.mjs",
    "lint": "node scripts/run-with-site.mjs pnpm exec eslint . --report-unused-disable-directives",
    "lint:deps": "node scripts/run-with-site.mjs pnpm exec depcruise --config dependency-cruiser.cjs --output-type err-long apps/web src cloudflare scripts tests",
    "arch:graph": "pnpm lint:deps",
    "arch:semantic": "node --test --import tsx \"src/architecture-boundaries.test.ts\"",
    "arch:check": "pnpm arch:graph && pnpm arch:semantic",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "conventions:draft": "node scripts/conventions-index.mjs --out .codex/drafts/CONVENTIONS.generated.md",
    "conventions:check": "node scripts/conventions-index.mjs --check",
    "db:generate": "npx drizzle-kit generate --config=src/infra/adapters/db/config.ts",
    "db:migrate": "npx drizzle-kit migrate --config=src/infra/adapters/db/config.ts",
    "db:check": "npx tsx scripts/check-db-schema.ts",
    "db:push": "npx drizzle-kit push --config=src/infra/adapters/db/config.ts",
    "db:studio": "npx drizzle-kit studio --config=src/infra/adapters/db/config.ts",
    "auth:generate": "node scripts/run-with-site.mjs pnpm exec @better-auth/cli generate --config=src/infra/platform/auth/index.ts",
    "rbac:init": "npx tsx scripts/init-rbac.ts",
    "rbac:assign": "npx tsx scripts/assign-role.ts",
    "postinstall": "node scripts/postinstall.mjs",
    "cf:check": "node scripts/run-with-site.mjs node --import tsx scripts/check-cloudflare-config.mjs",
    "cf:build": "node scripts/run-with-site.mjs node --import tsx scripts/run-cf-build.mjs",
    "cf:build:no-db": "node scripts/run-cf-build-no-db.mjs",
    "cf:deploy": "pnpm cf:deploy:app",
    "cf:deploy:state": "node scripts/run-with-site.mjs node --import tsx scripts/check-cloudflare-config.mjs --workers=state && node scripts/run-with-site.mjs node --import tsx scripts/run-cf-state-deploy.mjs",
    "cf:deploy:app": "pnpm cf:check -- --workers=app && pnpm cf:build && node scripts/run-with-site.mjs node --import tsx scripts/run-cf-app-deploy.mjs",
    "cf:preview:check": "CF_DEPLOY_PROFILE=preview pnpm cf:check",
    "cf:preview:build": "CF_DEPLOY_PROFILE=preview pnpm cf:build",
    "cf:preview:deploy:state": "CF_DEPLOY_PROFILE=preview pnpm cf:deploy:state",
    "cf:preview:deploy": "CF_DEPLOY_PROFILE=preview pnpm cf:deploy",
    "cf:preview:bootstrap": "CF_DEPLOY_PROFILE=preview CF_DEPLOY_BOOTSTRAP_MISSING=true pnpm cf:deploy",
    "site:contract": "node scripts/run-with-site.mjs node --import tsx scripts/site-contract.mjs",
    "site:gate": "node scripts/run-with-site.mjs node --import tsx scripts/site-gate.mjs",
    "site:preview:doctor": "node scripts/site-preview.mjs doctor",
    "site:preview:provision": "node scripts/site-preview.mjs provision",
    "site:preview:deploy": "node scripts/site-preview.mjs deploy",
    "site:production:doctor": "node scripts/site-production.mjs doctor",
    "site:production:init-settings": "node scripts/site-production.mjs init-settings",
    "site:production:provision": "node scripts/site-production.mjs provision",
    "release:cf": "node --import tsx scripts/run-local-cloudflare-release.mjs",
    "cf:typegen": "node scripts/run-with-site.mjs node --import tsx scripts/run-cf-typegen.mjs",
    "cf:typegen:check": "node scripts/run-with-site.mjs node --import tsx scripts/check-cf-typegen.mjs",
    "paraglide:compile": "pnpm exec paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy globalVariable baseLocale --is-server 'import.meta.env.SSR' --emit-ts-declarations --no-emit-git-ignore --no-emit-prettier-ignore --no-emit-readme",
    "client:boundary": "node scripts/check-client-bundle-boundary.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.89",
    "@hookform/resolvers": "^5.2.1",
    "@openrouter/ai-sdk-provider": "^1.2.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@tabler/icons-react": "^3.44.0",
    "@types/mdx": "^2.0.14",
    "ai": "^5.0.39",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "fumadocs-core": "^15.7.12",
    "fumadocs-mdx": "^11.10.0",
    "fumadocs-ui": "^15.7.12",
    "github-markdown-css": "^5.8.1",
    "github-slugger": "^2.0.0",
    "lucide-react": "^1.17.0",
    "markdown-it": "^14.1.1",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "overtype": "^1.2.6",
    "parse5": "^7.3.0",
    "postgres": "^3.4.9",
    "react": "19.2.7",
    "react-copy-to-clipboard": "^5.1.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.77.0",
    "react-icons": "^5.5.0",
    "react-use-measure": "^2.1.7",
    "recharts": "2.15.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "replicate": "^1.3.1",
    "resend": "^6.12.4",
    "rough-notation": "^0.5.1",
    "shiki": "^4.1.0",
    "simple-flakeid": "^0.0.5",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "use-stick-to-bottom": "^1.1.6",
    "uuid": "^14.0.1",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "@tanstack/react-start": "1.168.28",
    "@tanstack/react-router": "1.170.18"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@inlang/paraglide-js": "2.18.2",
    "@inlang/plugin-message-format": "4.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.10.34",
    "dependency-cruiser": "^17.4.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.37.0",
    "playwright": "1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "typescript-eslint": "8.61.0",
    "wrangler": "4.99.0",
    "vite": "8.0.16",
    "@vitejs/plugin-react": "6.0.2",
    "@cloudflare/vite-plugin": "1.40.1"
  },
  "pnpm": {
    "overrides": {
      "ajv@^6.12.4": "6.14.0",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "defu": "6.1.7",
      "dompurify": "3.4.0",
      "esbuild@~0.18.20": "0.25.12",
      "flatted": "3.4.2",
      "fast-xml-parser": "5.7.1",
      "lodash": "4.18.0",
      "lodash-es": "4.18.0",
      "minimatch@3": "3.1.5",
      "minimatch@9.0.5": "9.0.7",
      "path-to-regexp@8": "8.4.2",
      "picomatch@2": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "postcss": "8.5.15",
      "uuid": "14.0.1",
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  }
}
