      "dompurify": "3.4.0",
      "esbuild@~0.18.20": "0.25.12",
      "flatted": "3.4.2",
      "fast-xml-parser": "5.7.1",
      "lodash": "4.18.0",
      "lodash-es": "4.18.0",
      "minimatch@3": "3.1.5",
      "minimatch@9.0.5": "9.0.7",
      "path-to-regexp@8": "8.4.2",
