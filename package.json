{
  "name": "roller-rabbit",
  "version": "1.2.0",
  "private": true,
  "author": "Larrybin",
  "homepage": "https://github.com/Larrybin/aooi",
  "repository": {
    "type": "git",
    "url": "https://github.com/Larrybin/aooi.git"
  },
  "keywords": [
    "ai-saas-boilerplate",
    "ai-saas-template",
    "ai-saas-framework",
    "ai-saas-development"
  ],
  "scripts": {
    "dev": "node scripts/run-with-site.mjs pnpm exec next dev --turbopack",
    "dev:local": "SITE=dev-local node scripts/run-with-site.mjs pnpm exec next dev --turbopack",
    "dev:ai-remover:cloudflare": "SITE=ai-remover pnpm cf:build -- --workers=router,public-web && SITE=ai-remover node scripts/run-with-site.mjs node --import tsx scripts/run-ai-remover-cloudflare-dev.mjs",
    "build": "node scripts/run-with-site.mjs node scripts/next-build.mjs",
    "build:fast": "node scripts/run-with-site.mjs node scripts/next-build.mjs --max-old-space-size=4096",
    "analyze": "ANALYZE=true node scripts/run-with-site.mjs node scripts/next-build.mjs",
    "start": "node scripts/run-with-site.mjs pnpm exec next start",
    "test": "node scripts/run-with-site.mjs node scripts/run-tests.mjs",
    "test:extended": "pnpm test:auth-spike",
    "test:auth-spike": "node --import tsx scripts/smoke.mjs auth-spike",
    "test:cf-app-smoke": "node scripts/run-with-site.mjs node --import tsx scripts/smoke.mjs cf-app",
    "test:cf-admin-settings-smoke": "pnpm cf:build && node scripts/run-with-site.mjs node --import tsx scripts/smoke.mjs cf-admin-settings",
    "test:cf-local-smoke": "node scripts/run-with-site.mjs node --import tsx scripts/smoke.mjs cf-local",
    "test:admin-settings-module-contract-smoke": "node --import tsx scripts/run-admin-settings-module-contract-smoke.mjs",
    "test:creem-webhook-spike": "node --test --import tsx \"src/infra/adapters/payment/creem.test.ts\" \"tests/contract/payment-notify.test.ts\"",
    "test:remover-workers-ai-spike": "SITE=ai-remover pnpm cf:build -- --workers=router,public-web && SITE=ai-remover node scripts/run-with-site.mjs node --import tsx scripts/run-remover-workers-ai-spike.mjs",
    "test:r2-upload-spike": "node --test --import tsx \"src/app/api/storage/upload-image/route.test.ts\"",
    "test:coverage": "node scripts/run-with-site.mjs node scripts/run-tests.mjs --coverage",
    "contract:check": "node scripts/check-saas-product-contract.mjs",
    "lint": "node scripts/run-with-site.mjs pnpm exec eslint . --report-unused-disable-directives",
    "lint:deps": "node scripts/run-with-site.mjs pnpm exec depcruise --config dependency-cruiser.cjs --output-type err-long src cloudflare scripts tests",
    "arch:graph": "pnpm lint:deps",
    "arch:semantic": "node --test --import tsx \"src/architecture-boundaries.test.ts\"",
    "arch:check": "pnpm arch:graph && pnpm arch:semantic",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "conventions:draft": "node scripts/conventions-index.mjs --out .codex/drafts/CONVENTIONS.generated.md",
    "conventions:check": "node scripts/conventions-index.mjs --check",
    "db:generate": "npx drizzle-kit generate --config=src/infra/adapters/db/config.ts",
    "db:migrate": "npx drizzle-kit migrate --config=src/infra/adapters/db/config.ts",
    "db:check": "npx tsx scripts/check-db-schema.ts",
    "db:push": "npx drizzle-kit push --config=src/infra/adapters/db/config.ts",
    "db:studio": "npx drizzle-kit studio --config=src/infra/adapters/db/config.ts",
    "auth:generate": "node scripts/run-with-site.mjs pnpm exec @better-auth/cli generate --config=src/infra/platform/auth/index.ts",
    "rbac:init": "npx tsx scripts/init-rbac.ts",
    "rbac:assign": "npx tsx scripts/assign-role.ts",
    "postinstall": "node scripts/postinstall.mjs",
    "cf:check": "node scripts/run-with-site.mjs node --import tsx scripts/check-cloudflare-config.mjs",
    "cf:build": "node scripts/run-with-site.mjs node --import tsx scripts/run-cf-build.mjs",
    "cf:deploy": "pnpm cf:deploy:app",
    "cf:deploy:state": "node scripts/run-with-site.mjs node --import tsx scripts/check-cloudflare-config.mjs --workers=state && node scripts/run-with-site.mjs node --import tsx scripts/run-cf-state-deploy.mjs",
    "cf:deploy:app": "pnpm cf:check -- --workers=app && pnpm cf:build && node scripts/run-with-site.mjs node --import tsx scripts/run-cf-app-deploy.mjs",
    "cf:preview:check": "CF_DEPLOY_PROFILE=preview pnpm cf:check",
    "cf:preview:build": "CF_DEPLOY_PROFILE=preview pnpm cf:build",
    "cf:preview:deploy:state": "CF_DEPLOY_PROFILE=preview pnpm cf:deploy:state",
    "cf:preview:deploy": "CF_DEPLOY_PROFILE=preview pnpm cf:deploy",
    "cf:preview:bootstrap": "CF_DEPLOY_PROFILE=preview CF_DEPLOY_BOOTSTRAP_MISSING=true pnpm cf:deploy",
    "release:cf": "node --import tsx scripts/run-local-cloudflare-release.mjs",
    "cf:typegen": "node scripts/run-with-site.mjs node --import tsx scripts/run-cf-typegen.mjs",
    "cf:typegen:check": "node scripts/run-with-site.mjs node --import tsx scripts/check-cf-typegen.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.89",
    "@hookform/resolvers": "^5.2.1",
    "@next/bundle-analyzer": "16.2.6",
    "@next/env": "16.2.6",
    "@openrouter/ai-sdk-provider": "^1.2.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@tabler/icons-react": "^3.42.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/mdx": "^2.0.13",
    "ai": "^5.0.39",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "fumadocs-core": "^15.7.12",
    "fumadocs-mdx": "^11.10.0",
    "fumadocs-ui": "^15.7.12",
    "github-markdown-css": "^5.8.1",
    "github-slugger": "^2.0.0",
    "lucide-react": "^0.543.0",
    "markdown-it": "^14.1.1",
    "moment": "^2.30.1",
    "motion": "^12.38.0",
    "nanoid": "^5.1.6",
    "next": "16.2.6",
    "next-intl": "^4.11.1",
    "nextjs-toploader": "^3.9.17",
    "overtype": "^1.2.6",
    "parse5": "^7.3.0",
    "postgres": "^3.4.9",
    "react": "19.2.6",
    "react-copy-to-clipboard": "^5.1.1",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.5.0",
    "react-use-measure": "^2.1.7",
    "recharts": "2.15.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "replicate": "^1.3.1",
    "resend": "^6.12.3",
    "rough-notation": "^0.5.1",
    "server-only": "^0.0.1",
    "shiki": "^3.19.0",
    "simple-flakeid": "^0.0.5",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "use-stick-to-bottom": "^1.1.4",
    "uuid": "^14.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@opennextjs/cloudflare": "1.19.10",
    "@tailwindcss/postcss": "^4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.10.29",
    "dependency-cruiser": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.37.0",
    "eslint-config-next": "16.2.6",
    "playwright": "1.60.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
