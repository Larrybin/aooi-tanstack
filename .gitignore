# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/output/playwright/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.development
.env.test
.env.production
sites/*/.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Root-level scratch data (keep this scoped to repo root; avoid ignoring docs like docs/guides/database.md)
/data*
*debug*

*.db

.open-next
.wrangler

.debug 
.test

*.sql
!src/config/db/migrations/**/*.sql
.source

.chats

# nested starterkit (not part of main app)
/raphael-starterkit-v1-main/

.vercel

# local agent notes / scratch
/temp/
/.tmp/
/cloudflare/.tmp/

# local IDE history (do not commit)
.specstory/history/

.codex
.codex/context.md
.gstack/
.generated/
.cache/fumadocs/
