# aooi TanStack Gate 0-3 test environment example.
# Copy to .env.test or configure equivalent secrets in Codex/CI/Cloudflare.
# Never commit real sandbox keys or production secrets.

SITE=dev-local
DEPLOY_TARGET=cloudflare
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
STORAGE_PUBLIC_BASE_URL=
NEXT_PUBLIC_THEME=default

DATABASE_PROVIDER=postgresql
DATABASE_URL=
DB_SINGLETON_ENABLED=true

BETTER_AUTH_SECRET=
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
RESEND_API_KEY=

# Payment sandbox/test mode only.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_SECRET=
CREEM_API_KEY=
CREEM_SIGNING_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Future Gate AI/storage tests should use test/low-cost providers and test buckets.
OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=
FAL_API_KEY=
KIE_API_KEY=
AI_NOTIFY_WEBHOOK_SECRET=
REMOVER_CLEANUP_SECRET=
TURNSTILE_SECRET_KEY=
