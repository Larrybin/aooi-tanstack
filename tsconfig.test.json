{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "tsBuildInfoFile": ".tanstack/tsconfig.test.tsbuildinfo"
  },
  "include": [
    "src/shared/types/**/*.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "scripts/**/*.test.ts"
  ],
  "exclude": ["node_modules", "out", "dist", "raphael-starterkit-v1-main"]
}
