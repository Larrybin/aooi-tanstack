  "faq": {
    "id": "pricing-faq",
    "title": "Pricing questions before you generate.",
    "items": [
      {
        "question": "Does lifetime mean unlimited text to speech?",
        "answer": "No. Lifetime plans are permanent member entitlements with fixed monthly character quotas."
      },
      {
        "question": "When are Extra Credits used?",
        "answer": "Extra Credits are used only after the active monthly character quota is depleted."
      },
      {
        "question": "Can guests download MP3 files?",
        "answer": "No. Guests can preview generated speech, but MP3 downloads require sign-in."
      },
      {
        "question": "Does playback speed change the downloaded MP3?",
        "answer": "No. Playback speed changes only the browser audio player."
      }
    ]
  }
