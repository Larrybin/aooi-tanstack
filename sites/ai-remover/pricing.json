  "faq": {
    "id": "pricing-faq",
    "title": "Pricing questions before you upgrade.",
    "items": [
      {
        "question": "Can I use AI Remover for free?",
        "answer": "Yes. Guests can try low-res results before signing up. Creating an account unlocks the default free high-res allowance."
      },
      {
        "question": "Do paid plans include high-res downloads?",
        "answer": "Yes. Pro includes 300 high-res downloads per month, and Studio includes 1,500 high-res downloads per month."
      },
      {
        "question": "What happens when I cancel?",
        "answer": "Subscription benefits downgrade at the end of the active billing period. Your image retention and quota limits return to the free plan."
      },
      {
        "question": "Can I remove watermarks or logos?",
        "answer": "No. AI Remover is for legitimate photo cleanup and must not be used to remove copyright watermarks, brand logos, or authorization marks."
      }
    ]
  }
