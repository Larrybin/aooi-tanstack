# Copy this file to sites/ai-remover/.env.local for AI Remover-only local
# development. The .env.local file is ignored and must not be committed.

# database
# Local Node.js commands use DATABASE_URL. Cloudflare deploys use Hyperdrive IDs
# from deploy.settings.json / deploy.preview.settings.json instead.
DATABASE_URL = ""
DATABASE_PROVIDER = "postgresql"
DB_SINGLETON_ENABLED = "true"

# auth
BETTER_AUTH_SECRET = ""
AUTH_SECRET = ""
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""
RESEND_API_KEY = ""

# payment
CREEM_API_KEY = ""
CREEM_SIGNING_SECRET = ""

# storage
STORAGE_PUBLIC_BASE_URL = ""

# remover AI
REMOVER_AI_PROVIDER = "cloudflare-workers-ai"
REMOVER_AI_MODEL = "@cf/runwayml/stable-diffusion-v1-5-inpainting"
REMOVER_CLEANUP_SECRET = ""
